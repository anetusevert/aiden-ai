# PostgreSQL
POSTGRES_USER=aiden
POSTGRES_PASSWORD=aiden_dev_password
POSTGRES_DB=aiden
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aiden:aiden_dev_password@postgres:5432/aiden
# Optional: host port for docker-compose postgres publish (default 5432). Example if 5432 is taken:
# POSTGRES_HOST_PORT=15432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MinIO Container Configuration (used by MinIO itself)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=aiden-storage

# S3/MinIO Storage Configuration (canonical S3_* vars for API)
# These are the canonical env vars used by the API.
# Legacy AWS_* vars are supported as fallback but deprecated.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=aiden-storage
S3_REGION=us-east-1
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true

# API
API_HOST=0.0.0.0
API_PORT=8000

# API Root Path (for reverse proxy mounting)
# Set to "/api" when running behind a reverse proxy that mounts the API at /api
# This configures FastAPI's root_path for correct OpenAPI docs and URL generation
# Default: "" (empty, direct access at root)
# API_ROOT_PATH=/api

# Environment (dev | staging | prod)
# Controls security features like dev-login and cookie secure flags
ENVIRONMENT=dev

# CORS (comma-separated list of allowed origins)
# Default: http://localhost:3000,http://127.0.0.1:3000
# Add https://localhost when using Caddy HTTPS proxy
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://localhost

# ============================================================================
# Authentication Configuration (Cookie-based with Refresh Token Rotation)
# ============================================================================
# Authentication uses httpOnly cookies with refresh token rotation.
# See apps/api/README.md for full documentation.
#
# Token Expiration:
#   - ACCESS_TOKEN_EXPIRES_MINUTES: Short-lived access token (default: 15)
#   - REFRESH_TOKEN_EXPIRES_DAYS: Long-lived refresh token (default: 7)
#
# Cookie Security:
#   - Secure flag is auto-derived from ENVIRONMENT (dev=false, staging/prod=true)
#   - Override with COOKIE_SECURE if needed
# ============================================================================

# JWT secret (CHANGE IN PRODUCTION!)
JWT_SECRET=INSECURE_DEV_SECRET_CHANGE_IN_PRODUCTION

# Token expiration
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7

# Auth mode: jwt (cookie-based, default) or headers (legacy/debug)
AUTH_MODE=jwt

# Dev login endpoint (ONLY allowed when ENVIRONMENT=dev)
AUTH_ALLOW_DEV_LOGIN=true

# ============================================================================
# Web Frontend Configuration
# ============================================================================
# API URL Resolution:
#   - NEXT_PUBLIC_API_BASE_URL: Full URL for cross-origin mode (e.g., http://localhost:8000)
#   - NEXT_PUBLIC_API_PREFIX: Path prefix for same-origin mode (default: /api)
#   - API_INTERNAL_BASE_URL: Server-side URL for Docker SSR (e.g., http://api:8000)
#
# Modes:
#   - Cross-origin (dev): Set NEXT_PUBLIC_API_BASE_URL, web at :3000, API at :8000
#   - Same-origin (proxy): Unset NEXT_PUBLIC_API_BASE_URL, use NEXT_PUBLIC_API_PREFIX
#
# HTTPS Proxy Mode (.\infra\dev.ps1 proxy-up):
#   - Web and API served from https://localhost via Caddy reverse proxy
#   - NEXT_PUBLIC_API_BASE_URL should be UNSET (or empty)
#   - NEXT_PUBLIC_API_PREFIX=/api
#   - API_ROOT_PATH=/api (FastAPI knows it's mounted at /api)
#   - Cookies work with SameSite=Lax, no CORS issues
# ============================================================================

# Client-side API URL (browser requests) - cross-origin mode for local dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Optional: host port for docker-compose web publish (default 3000). Example if 3000 is taken:
# WEB_HOST_PORT=3001

# Same-origin API prefix (used when NEXT_PUBLIC_API_BASE_URL is not set)
# Set this and unset NEXT_PUBLIC_API_BASE_URL for same-origin proxy mode
# NEXT_PUBLIC_API_PREFIX=/api

# Server-side API URL (SSR requests) - set in docker-compose.yml
# API_INTERNAL_BASE_URL=http://api:8000

# ============================================================================
# API Root Path (for reverse proxy mounting)
# ============================================================================
# When running behind Caddy proxy at /api path, set API_ROOT_PATH=/api
# This configures FastAPI's root_path for correct OpenAPI docs and URL generation
# Default: "" (empty, direct access at root)
# For proxy mode: API_ROOT_PATH=/api
# ============================================================================

# ============================================================================
# Cookie Security Override
# ============================================================================
# By default, Secure flag is auto-derived from ENVIRONMENT:
#   - ENVIRONMENT=dev → Secure=false (allows http://localhost)
#   - ENVIRONMENT=staging/prod → Secure=true (requires HTTPS)
#
# When testing HTTPS locally with Caddy proxy, you can force Secure cookies:
#   COOKIE_SECURE=true
#
# This allows testing Secure cookie behavior under local TLS.
# ============================================================================
# COOKIE_SECURE=true

# ============================================================================
# LLM Provider Configuration (Provider Relay)
# ============================================================================
# The LLM Provider Relay selects the appropriate LLM backend based on config.
# See apps/api/README.md for full documentation.
#
# Behavior:
#   - LLM_PROVIDER=stub: Uses deterministic stub (default, no API key needed)
#   - LLM_PROVIDER=openai + LLM_API_KEY set: Uses OpenAI
#   - LLM_PROVIDER=openai + no API key + ENVIRONMENT=dev: Falls back to stub
#   - LLM_PROVIDER=openai + no API key + ENVIRONMENT!=dev: Hard fails at startup
# ============================================================================

# Default: Stub provider for development/testing
LLM_PROVIDER=stub

# To enable OpenAI (required for Amin agent with tool calling), uncomment:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-openai-api-key-here
#
# Note: Amin agent features (chat, tool calling, streaming) require a real
# LLM provider. In stub mode, Amin returns echo-style responses.
