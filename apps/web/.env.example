# Client-side API URL (browser requests)
# Use the same hostname you use for the web app (localhost OR 127.0.0.1 — never mix),
# or httpOnly SameSite=Lax login cookies will not attach to API requests.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Server-side API URL (SSR requests)
# In Docker: http://api:8000 (internal network)
# Outside Docker: http://localhost:8000 (or same as client URL)
API_INTERNAL_BASE_URL=http://localhost:8000

# Collabora Online (document editor)
# Browser-accessible URL — must NOT be a Docker-internal hostname
NEXT_PUBLIC_COLLABORA_URL=http://localhost:9980
# Set to false to disable Collabora and always show fallback download UI
NEXT_PUBLIC_COLLABORA_ENABLED=true
