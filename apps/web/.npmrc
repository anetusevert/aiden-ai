# pnpm configuration for Windows compatibility
# 
# Windows has symlink restrictions that cause Next.js standalone builds to fail
# with "EPERM: operation not permitted, symlink" errors.
#
# Setting node-linker=hoisted avoids symlinks by hoisting dependencies to
# node_modules root, similar to npm/yarn behavior.
#
# This does NOT affect Docker builds (Linux has no symlink restrictions).

node-linker=hoisted
