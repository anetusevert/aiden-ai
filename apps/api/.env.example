# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS (comma-separated list of allowed origins)
# Default: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql://aiden:aiden_dev_password@postgres:5432/aiden

# Redis
REDIS_URL=redis://redis:6379/0

# ============================================================================
# S3/MinIO Storage Configuration (Canonical S3_* vars)
# ============================================================================
# These are the canonical environment variables for S3/MinIO storage.
# Legacy AWS_* vars are supported as fallback but deprecated.
# For local development with MinIO via docker-compose, use these defaults.

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=aiden-storage
S3_REGION=us-east-1
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true

# ============================================================================
# Authentication Configuration
# ============================================================================

# AUTH_MODE: "jwt" (default) or "headers" (legacy dev mode)
# - jwt: Uses Bearer token authentication (recommended)
# - headers: Uses X-Tenant-Id, X-User-Id, X-Workspace-Id headers (for debugging)
AUTH_MODE=jwt

# JWT Configuration
# WARNING: The default secret is INSECURE and for development only!
# Generate a strong secret for production: openssl rand -hex 32
JWT_SECRET=INSECURE_DEV_SECRET_CHANGE_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Dev Login
# Set to false in production to disable the /auth/dev-login endpoint
AUTH_ALLOW_DEV_LOGIN=true

# ============================================================================
# LLM Provider Configuration (Provider Relay)
# ============================================================================
# The LLM Provider Relay implements smart provider selection with environment-
# aware fallback behavior. See README.md for the full behavior matrix.
#
# LLM_PROVIDER: Which LLM backend to use
#   - "stub" (default): Deterministic stub for testing/development
#   - "openai": OpenAI API (requires LLM_API_KEY)
#
# LLM_MODEL: Model name (optional, uses provider default)
#   - For OpenAI: "gpt-4o-mini" (default), "gpt-4o", "gpt-4-turbo", etc.
#   - For Stub: "stub-v1" (always)
#
# LLM_API_KEY: API key (required for OpenAI provider)
#   - If LLM_PROVIDER=openai and key is missing:
#     - ENVIRONMENT=dev: Falls back to Stub with loud warning
#     - ENVIRONMENT=staging/prod: Hard fails at startup
#
# ============================================================================

# Default: Stub provider (no API key needed, deterministic output)
LLM_PROVIDER=stub

# ============================================================================
# To enable OpenAI, uncomment the following lines:
# ============================================================================
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-your-openai-api-key-here
